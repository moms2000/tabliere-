# ── TablièreCI Backend — Variables d'environnement ─────────────────────────
# Copier ce fichier en .env et remplir les valeurs

NODE_ENV=development
PORT=4000

# ── Base de données PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tabliereci

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_me_refresh_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_IN=30d

# ── URLs ─────────────────────────────────────────────────────────────────────
APP_URL=https://tabliereci.ci
FRONTEND_URL=http://localhost:3000

# ── SendGrid (emails transactionnels) ────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@tabliereci.ci

# ── WhatsApp Business API (Meta) ─────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Orange Money CI ──────────────────────────────────────────────────────────
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/ci/v1

# ── MTN MoMo ─────────────────────────────────────────────────────────────────
MTN_MOMO_API_KEY=
MTN_MOMO_USER_ID=
MTN_MOMO_API_SECRET=
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_ENVIRONMENT=sandbox

# ── Wave ─────────────────────────────────────────────────────────────────────
WAVE_API_KEY=
WAVE_BASE_URL=https://api.wave.com/v1

# ── Stripe (cartes bancaires) ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
